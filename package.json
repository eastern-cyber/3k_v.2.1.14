{
  "name": "kokkokkok-auth-api",
  "version": "1.0.0",
  "description": "KokKokKok Authentication API",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "dev": "vercel dev",
    "start": "node server.js",
    "deploy": "vercel --prod",
    "css": "tailwindcss -i ./static/css/tailwind.css -o ./static/css/style.css --watch",
    "minify": "tailwindcss -i ./static/css/tailwind.css -o ./static/css/style.css --minify",
    "freeze": "pip freeze > requirements.txt"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.3",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "tailwindcss": "^4.1.3"
  }
}
